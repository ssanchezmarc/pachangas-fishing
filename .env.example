# Supabase — rellena con los valores del proyecto (ver todo-list / ONBOARDING).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Solo servidor (service role): NUNCA exponer en el cliente.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Private bucket for scorecard photos (evidence).
SUPABASE_STORAGE_BUCKET=scorecards

# --- Phase 1: AI reading (slice 07 — model decided: GPT-4o vision) ---
# Leave AI_PROVIDER unset to use the built-in mock reader (no LLM cost, used in CI).
# Set it to "openai" + your key to use the real GPT-4o reader.
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o   # optional override

# --- Phase 2: WhatsApp Cloud API (pending Meta Business onboarding, slice 10) ---
WHATSAPP_VERIFY_TOKEN=change-me
# App secret for the X-Hub-Signature-256 payload check (optional; if unset the
# webhook does NOT verify signatures — fine for local/CI).
# WHATSAPP_APP_SECRET=
# Numbers allowed to send scorecards, comma-separated (RF-3).
WHATSAPP_WHITELIST=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=

# --- Phase 2: Inngest queue (slice 10). Dev: `npx inngest-cli dev` (keyless).
# Production needs these from the Inngest dashboard:
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# --- Phase 3: standings push to the group (slice 13). ---
# Public base URL used to build the live-standings link in the push.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Recipient of the published-standings summary (the group's relay number /
# organizer). Unset = the push is skipped (logged).
# WHATSAPP_GROUP_RECIPIENT=
